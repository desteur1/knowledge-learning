{% extends 'base.html.twig' %}

{% block title %}Mes cours{% endblock %}

{% block body %}
<div class="courses-container">

    <h1>Mes cours</h1>

    <div class="subnav">
        <a href="{{ path('app_my_courses') }}" class="active">Mes cursus</a>
        <a href="{{ path('app_my_lessons') }}">Mes leçons achetées</a>
   </div>

    {% if courses is empty %}
        <p>Vous n'avez encore acheté aucun cours.</p>
    {% else %}
        <div class="courses-list">
            {% for cursus in courses %}
                <div class="course-card">
                    <h2>{{ cursus.name }}</h2>

                    <p>
                        {{ cursus.lessons|length }} leçons dans ce cursus.
                    </p>

                    {% set validated = app.user.countUserValidatedLessonsForCursus(cursus) %}
                    {% set total = cursus.lessons|length %}

                    {% if validated == total %}
                        <span class="badge bg-success">🎓 100% terminé</span>
                        <a href="{{ path('cursus_show', { id: cursus.id }) }}" class="btn btn-secondary mt-2">
                            Voir le cursus
                        </a>
                    {% else %}
                        <a href="{{ path('cursus_show', { id: cursus.id }) }}" class="btn btn-primary mt-2">
                            Continuer
                        </a>
                    {% endif %}

                    {% set percent = (validated / total * 100)|round %}

                    <p>Progression : {{ percent }}%</p>

                    <div style="background:#ddd; width:100%; height:8px; border-radius:4px;">
                        <div style="background:#4caf50; width:{{ percent }}%; height:100%; border-radius:4px;"></div>
                    </div>


                </div>
            {% endfor %}
        </div>
    {% endif %}

</div>

<style>
.courses-container {
    max-width: 900px;
    margin: 40px auto;
    padding: 20px;
}

.subnav {
    margin-bottom: 20px;
}

.subnav a {
    margin-right: 15px;
    text-decoration: none;
    color: #007bff;
}

.subnav a.active {
    font-weight: bold;
    text-decoration: underline;
}

.courses-list {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 20px;
}

.course-card {
    border: 1px solid #ddd;
    padding: 20px;
    border-radius: 8px;
}

.btn {
    display: inline-block;
    margin-top: 10px;
    padding: 8px 14px;
    background: #333;
    color: white;
    text-decoration: none;
    border-radius: 5px;
}
</style>
{% endblock %}
