{% extends 'base.html.twig' %}

{% block title %}{{ cursus.name }}{% endblock %}

{% block body %}
<div class="example-wrapper">

    {% set total = lessons|length %}

    {% if app.user %}
        {% set validated = app.user.countValidatedLessonsForCursus(cursus) %}
        {% set next = app.user.getNextLessonToStudy(cursus) %}
    {% else %}
        {% set validated = 0 %}
        {% set next = null %}
    {% endif %}

    {% set percent = (validated / total * 100)|round %}

    <h2>Leçons du cursus</h2>

    <ul>
        {% for lesson in lessons %}
            <li>
                {{ lesson.name }} - {{ lesson.price }} €

                {% if app.user and (app.user.hasPurchasedLesson(lesson) or app.user.hasPurchasedCursus(cursus)) %}

                    {% set isValidated = false %}
                    {% for v in app.user.lessonValidations %}
                        {% if v.lesson.id == lesson.id %}
                            {% set isValidated = true %}
                        {% endif %}
                    {% endfor %}

                    {% if isValidated %}
                        <span style="color: green; font-weight: bold;">Validée ✔</span>
                    {% else %}
                        <a href="{{ path('lesson_show', {id: lesson.id}) }}">Accéder</a>
                    {% endif %}

                {% else %}
                    <a href="{{ path('purchase_lesson', {id: lesson.id}) }}">Acheter</a>
                {% endif %}
            </li>
        {% endfor %}
    </ul>

    <hr>

    {% if app.user and app.user.hasPurchasedCursus(cursus) %}
        <strong>Vous avez déjà acheté ce cursus.</strong><br>

        {% if validated == 0 %}
            <a href="{{ path('lesson_show', {id: lessons|first.id}) }}">
                Commencer le cursus
            </a>

        {% elseif next %}
            <a href="{{ path('lesson_show', {id: next.id}) }}" class="btn btn-primary mt-3">
                Continuer le cursus
            </a>

        {% else %}
            <strong>🎉 Toutes les leçons sont validées !</strong>
        {% endif %}

    {% else %}
        <a href="{{ path('purchase_cursus', {id: cursus.id}) }}">
            Acheter ce cursus ({{ cursus.price }} €)
        </a>
    {% endif %}

    <h3>Progression du cursus</h3>
    <p>{{ validated }} leçons validées sur {{ total }} ({{ percent }}%)</p>

    <div style="background:#ddd; width:300px; height:20px; border-radius:5px;">
        <div style="background:#4caf50; width:{{ percent }}%; height:100%; border-radius:5px;"></div>
    </div>

    {% if app.user and app.user.hasCertificationForCursus(cursus) %}
        <div class="alert alert-success mt-3">
            🎓 Vous avez obtenu la certification de ce cursus !
        </div>
    {% endif %}

</div>
{% endblock %}
