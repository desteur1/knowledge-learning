{% extends 'base.html.twig' %}

{% block body %}

<h1>{{ lesson.name }}</h1>

<p>Prix : {{ lesson.price }} €</p>

<p>{{ lesson.content }}</p>

<video src="{{ lesson.videoUrl }}" controls width="600"></video>

<hr>

{% if user and (user.hasPurchasedLesson(lesson) or user.hasPurchasedCursus(lesson.cursus)) %}
    <strong>Vous avez accès à cette leçon.</strong>
{% else %}
    <a href="{{ path('purchase_lesson', {id: lesson.id}) }}" class="btn btn-primary mt-3">
        Acheter cette leçon ({{ lesson.price }} €)
    </a>
{% endif %}

<hr>

{% if user and (user.hasPurchasedLesson(lesson) or user.hasPurchasedCursus(lesson.cursus)) %}

    {% set validated = false %}
    {% for v in user.lessonValidations %}
        {% if v.lesson.id == lesson.id %}
            {% set validated = true %}
        {% endif %}
    {% endfor %}

    {% if validated %}
        <strong>Leçon validée ✔</strong>
    {% else %}
        <a href="{{ path('lesson_validate', {id: lesson.id}) }}" class="btn btn-success mt-3">
            Valider cette leçon
        </a>
    {% endif %}

{% endif %}

{% set next = user.getNextLessonToStudy(lesson.cursus) %}

{% if next and next.id != lesson.id %}
    <a href="{{ path('lesson_show', {id: next.id}) }}" class="btn btn-success mt-3">
        Leçon suivante →
    </a>
{% endif %}


{% endblock %}

