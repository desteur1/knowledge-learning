{% extends 'base.html.twig' %}

{% block title %}Mon profil{% endblock %}

{% block body %}
<div class="profile-container">

    <h1>Mon profil</h1>

    <div class="profile-card">

    {% for message in app.flashes('success') %}
    <div class="flash-success">{{ message }}</div>
    {% endfor %}

    {% for message in app.flashes('error') %}
        <div class="flash-error">{{ message }}</div>
    {% endfor %}

        <p><strong>Email :</strong> {{ user.email }}</p>

        <p>
            <strong>Statut :</strong>
            {% if user.isVerified %}
                <span class="verified">✔ Vérifié</span>
            {% else %}
                <span class="not-verified">✖ Non vérifié</span>
                <br>
                <a href="{{ path('app_resend_verification_email') }}" class="btn">Vérifier mon email</a>
            {% endif %}
        </p>

        <p><strong>Rôle :</strong> {{ user.role.name }}</p>

        <a href="{{ path('app_change_password') }}" class="btn">Changer mon mot de passe</a>
    </div>

</div>

<style>
.profile-container {
    max-width: 600px;
    margin: 40px auto;
    padding: 20px;
}

.profile-card {
    padding: 20px;
    border: 1px solid #ddd;
    border-radius: 8px;
}

.flash-success {
    background: #ddffdd;
    padding: 10px;
    border-left: 4px solid green;
    margin-bottom: 10px;
}

.flash-error {
    background: #ffdddd;
    padding: 10px;
    border-left: 4px solid red;
    margin-bottom: 10px;
}


.verified {
    color: green;
    font-weight: bold;
}

.not-verified {
    color: red;
    font-weight: bold;
}

.btn {
    display: inline-block;
    margin-top: 10px;
    padding: 8px 14px;
    background: #333;
    color: white;
    text-decoration: none;
    border-radius: 5px;
}
</style>
{% endblock %}
